  <ItemGroup>
    <ProjectReference Include="..\Zakira.Exchange.Core\Zakira.Exchange.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.CommandLine" Version="2.0.0-beta5.25306.1" />
  </ItemGroup>

</Project>
