<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <PackageId>Zakira.Exchange.Cli</PackageId>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>zakira-cli</ToolCommandName>
    <Description>CLI tool for Zakira.Exchange - AI agent memory storage and semantic search</Description>
    <PackageTags>mcp;memory;ai;search;embeddings;sqlite;cli;dotnet-tool</PackageTags>
